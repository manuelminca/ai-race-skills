# Environment variables for ai-race-skills
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Google Maps API (for location-intel)
# GOOGLE_MAPS_API_KEY=your_key_here

# gog CLI for Google Calendar (for calendar-manager)
# GOG_ACCOUNT=your@gmail.com
# GOG_KEYRING_PASSWORD=your_keyring_password

# Microsoft Graph / Outlook (for outlook-email)
# OUTLOOK_CLIENT_ID=your_azure_app_client_id
# OUTLOOK_CONFIG_DIR=~/.outlook-mail
